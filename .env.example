# Vibefy — copy to .env

# Audius (optional) https://api.audius.co/plans
VITE_AUDIUS_API_KEY=

# Jamendo https://developer.jamendo.com
VITE_JAMENDO_CLIENT_ID=

# FREE AI music (MusicGen) — optional
# For Static HF Spaces, set as Space *variable* named VITE_HF_TOKEN
# https://huggingface.co/settings/tokens  → Read token
VITE_HF_TOKEN=
HF_TOKEN=


# Optional AI lyrics
GROQ_API_KEY=

# Optional YouTube discover enrichment
YOUTUBE_API_KEY=
